PBX_LOCATION_SLUG=version-hq
PBX_LAN_IP=10.30.0.10
PBX_WARP_IP=100.64.30.10
TZ=America/Los_Angeles

# Asterisk is built locally from pinned Asterisk 20 source and the Cisco USECALLMANAGER patch.
ASTERISK_VERSION=20.19.0
ASTERISK_SOURCE_URL=https://downloads.asterisk.org/pub/telephony/asterisk/old-releases/asterisk-20.19.0.tar.gz
ASTERISK_SOURCE_SHA256=10fbc070f9aaec50b788962dbcddf694fcc61d49c1f1bb158bf04a2e7e46aba0
CISCO_PATCH_URL=https://raw.githubusercontent.com/usecallmanagernz/patches/master/asterisk/cisco-usecallmanager-20.19.0.patch
CISCO_PATCH_SHA256=adcb88c17a1cf8eb6242c7d9f1959f06afc64ae9af210268abaf767d388b83d2

# Prebuilt custom runtime image overrides should include immutable digests where practical.
PBX_ASTERISK_IMAGE=pbx-asterisk:20.19.0-cisco
PBX_TFTP_IMAGE=
PBX_HTTP_IMAGE=docker.io/nginx:1.27-alpine
PBX_AGENT_IMAGE=

PROVISIONING_TFTP_PORT=69
PROVISIONING_HTTP_PORT=80

ASTERISK_UID=1000
ASTERISK_GID=1000
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=ami-branch
ASTERISK_AMI_SECRET=ami-secret
ASTERISK_CDR_CSV_PATH=/var/log/asterisk/cdr-csv/Master.csv
ASTERISK_CEL_CSV_PATH=/var/log/asterisk/cel-custom/Master.csv
ASTERISK_RECORDING_ROOT=/var/spool/asterisk/monitor

PBX_AGENT_WS_URL=wss://portal.example.test/api/agent/ws/
PBX_AGENT_TOKEN=agent-token
PBX_AGENT_SECRET=agent-secret
PBX_ACTIVE_CONFIG_MARKER=/etc/asterisk/pbx-active-config.json
PBX_AGENT_TELEMETRY_INTERVAL_SECONDS=60
PORTAL_API_BASE_URL=
